# Copy this file to .env and fill in the real values before starting the stack.
# Hasan also supports file-backed secrets in ./secrets/ or mounted *_FILE paths.

# Required for the API/admin flows unless you create secrets/admin_token.
ADMIN_TOKEN=replace-with-a-strong-secret

# Optional shared token for older SL objects. Leave blank if you are using signed requests only.
JLS_SHARED_TOKEN=

# Optional signing secret. Required when JLS_REQUIRE_SIGNED_REQUESTS=1.
JLS_SIGNING_SECRET=
JLS_REQUIRE_SIGNED_REQUESTS=0
JLS_SIGNING_MAX_SKEW_SEC=120
JLS_SIGNING_NONCE_TTL_SEC=300

# Optional file-based secret paths if you mount secrets somewhere other than ./secrets or /run/secrets.
# ADMIN_TOKEN_FILE=/run/secrets/admin_token
# JLS_SHARED_TOKEN_FILE=/run/secrets/jls_shared_token
# JLS_SIGNING_SECRET_FILE=/run/secrets/jls_signing_secret
# DB_PASS_FILE=/run/secrets/db_pass

BASE_URL=http://localhost:3000
WS_URL=ws://localhost:3010
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=password
DB_NAME=jls
REDIS_URL=redis://127.0.0.1:6379
PORT=3000
WS_PORT=3010
RATE_LIMIT_MS=800
LOG_LEVEL=info
