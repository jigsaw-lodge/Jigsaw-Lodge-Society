void triggerEvent(string t, string avatar, integer ts)\
\{\
    integer dur;\
    vector c;\
    float glow;\
    string label;\
\
    activeEventType = t;\
    activeEventAvatar = avatar;\
    activeEventTs = ts;\
\
    c = eventColor(t);\
    glow = eventGlow(t);\
    dur = eventDuration(t);\
\
    effectColor = c;\
    effectGlow = glow;\
    effectUntil = llGetUnixTime() + dur;\
    particleUntil = llGetUnixTime() + 2;\
\
    label = eventLabel(t);\
\
    if (objectRole == "chair")\
        label = "CHAIR\\n" + label;\
    else if (objectRole == "board")\
        label = "BOARD\\n" + label;\
    else if (objectRole == "feed")\
        label = "FEED\\n" + label;\
    else\
        label = "JLS\\n" + label;\
\
    burstParticles(c);\
    applyVisualState(c, glow, label);\
\
    if (DEBUG)\
    \{\
        debugSay("Event feedback: " + t + " @" + avatar);\
