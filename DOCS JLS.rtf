void applyVisualState(vector color, float glow, string label)\
\{\
    glow = clampFloat(glow, 0.0, 0.8);\
\
    llSetLinkPrimitiveParamsFast(\
        LINK_SET,\
        [\
            PRIM_COLOR, ALL_SIDES, color, 1.0,\
