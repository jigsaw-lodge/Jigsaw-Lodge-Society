// Detects nearby avatars and sends watcher counts to backend.\
\
string API_MAIN = "http://89.167.94.250:3000/api/event";\
string API_FALLBACK = "https://jigsawlodgesociety.com/api/event";\
string API;\
\
integer DEBUG = TRUE;\
integer REQUEST_TIMEOUT = 6;\
integer MAX_RETRIES = 3;\
\
integer activeWatchers = 0;\
integer lastSentWatchers = -1;\
integer requestRetryCount = 0;\
integer requestPending = FALSE;\
integer requestSentUnix = 0;\
integer nextRequestUnix = 0;\
key activeRequest = NULL_KEY;\
\
debugSay(string msg)\
\{\
    if (DEBUG) llOwnerSay(msg);\
\}\
\
integer clampInt(integer v, integer minV, integer maxV)\
\{\
    if (v < minV) return minV;\
    if (v > maxV) return maxV;\
    return v;\
\}\
\
string sendBody()\
\{\
    return llList2Json(JSON_OBJECT, [\
        "avatar", (string)llGetOwner(),\
        "object", (string)llGetKey(),\
        "action", "hud_tick",\
        "watchers", activeWatchers\
    ]);\
\}\
\
sendSync()\
\{\
    string body = sendBody();\
\
    activeRequest = llHTTPRequest(\
        API,\
        [HTTP_METHOD, "POST", HTTP_MIMETYPE, "application/json"],\
        body\
    );\
\
    requestPending = TRUE;\
    requestSentUnix = llGetUnixTime();\
    lastSentWatchers = activeWatchers;\
\}\
\
integer markFailure(string reason)\
\{\
    requestPending = FALSE;\
    activeRequest = NULL_KEY;\
    requestRetryCount++;\
\
    if (requestRetryCount == 1 && API == API_MAIN)\
    \{\
        API = API_FALLBACK;\
        nextRequestUnix = llGetUnixTime() + 1;\
        debugSay("Zone beacon switching to fallback.");\
        return TRUE;\
    \}\
\
    if (requestRetryCount < MAX_RETRIES)\
    \{\
        nextRequestUnix = llGetUnixTime() + 1;\
        return TRUE;\
    \}\
\
    if (DEBUG) llOwnerSay("JLS zone beacon sync unavailable.");\
    return FALSE;\
\}\
\
maybeSend()\
\{\
    integer now = llGetUnixTime();\
\
    if (requestPending)\
    \{\
        if ((now - requestSentUnix) > REQUEST_TIMEOUT)\
            markFailure("timeout");\
        return;\
    \}\
\
    if (activeWatchers != lastSentWatchers || now >= nextRequestUnix)\
    \{\
        sendSync();\
        nextRequestUnix = now + 5;\
    \}\
\}\
\
default\
\{\
    state_entry()\
    \{\
        API = API_MAIN;\
        llSetText("ZONE BEACON\\n0 watchers", <1,1,1>, 1.0);\
        llSensorRepeat("", NULL_KEY, AGENT, 7.0, PI, 3.0);\
        llSetTimerEvent(5.0);\
    \}\
\
    sensor(integer n)\
    \{\
        activeWatchers = clampInt(n, 0, 99);\
        llSetText("ZONE BEACON\\n" + (string)activeWatchers + " watchers", <1,1,1>, 1.0);\
        maybeSend();\
    \}\
\
    no_sensor()\
    \{\
        activeWatchers = 0;\
        llSetText("ZONE BEACON\\n0 watchers", <1,1,1>, 1.0);\
        maybeSend();\
    \}\
\
    timer()\
    \{\
        maybeSend();\
    \}\
\
    http_response(key id, integer status, list meta, string body)\
    \{\
        if (id != activeRequest) return;\
\
        requestPending = FALSE;\
        activeRequest = NULL_KEY;\
\
        if (status != 200)\
        \{\
            markFailure("http " + (string)status);\
            return;\
        \}\
\
        requestRetryCount = 0;\
        if (DEBUG) debugSay("Zone beacon OK: " + body);\
    \}\
\
    changed(integer change)\
    \{\
        if (change & CHANGED_OWNER) llResetScript();\
    \}\
\
    on_rez(integer start_param)\
    \{\
        llResetScript();\
    \}\
\}\
