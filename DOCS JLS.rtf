    );\
\
    requestPending = TRUE;\
    requestSentUnix = llGetUnixTime();\
    pendingHoney = honey;\
\}\
\
integer markFailure(string reason)\
\{\
    requestPending = FALSE;\
    activeRequest = NULL_KEY;\
    requestRetryCount++;\
\
    if (requestRetryCount == 1 && API == API_MAIN)\
    \{\
        API = API_FALLBACK;\
        nextRequestUnix = llGetUnixTime() + 1;\
        debugSay("Honey kiosk switching to fallback.");\
        return TRUE;\
    \}\
\
    if (requestRetryCount < MAX_RETRIES)\
    \{\
        nextRequestUnix = llGetUnixTime() + 1;\
        return TRUE;\
    \}\
\
    llOwnerSay("JLS honey kiosk unavailable.");\
    return FALSE;\
\}\
\
