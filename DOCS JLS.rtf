string progressBar(integer pct)\
\{\
    integer i;\
    integer total = 12;\
    integer filled = (clampInt(pct,0,100) * total) / 100;\
\
    string bar = "";\
\
    for (i = 0; i < total; i++)\
    \{\
        if (i < filled) bar += "\uc0\u9608 ";\
        else bar += "\uc0\u9617 ";\
    \}\
\
    // \uc0\u55357 \u56613  PRESSURE ZONE (90+)\
    if (pct >= 90)\
    \{\
        if (llFrand(1.0) > 0.6)\
        \{\
            integer pos = total - 1;\
            bar = llDeleteSubString(bar, pos, pos) + "\uc0\u9619 ";\
        \}\
    \}\
\
    return bar;\
\}\
