\
void refreshAmbient()\
\{\
    integer now;\
    float pulse;\
    float baseGlow;\
    float watcherFactor;\
    vector color;\
    string label;\
\
    now = llGetUnixTime();\
\
    watcherFactor = 0.02 + (0.01 * (float)clampInt(totalWatchers, 0, 10));\
    baseGlow = clampFloat(watcherFactor, 0.02, 0.20);\
\
    pulse = 0.82 + (0.18 * llSin((float)now * (0.85 + (0.02 * (float)totalWatchers))));\
    color = <0.88, 0.92, 1.0> * pulse;\
\
    label = "JLS\\nwatchers " + (string)totalWatchers;\
\
    if (objectRole == "chair")\
        label = "CHAIR\\nwatchers " + (string)totalWatchers;\
    else if (objectRole == "board")\
        label = "BOARD\\nwatchers " + (string)totalWatchers;\
    else if (objectRole == "feed")\
        label = "FEED\\nwatchers " + (string)totalWatchers;\
\
    if (now < effectUntil)\
    \{\
        color = effectColor;\
        baseGlow = effectGlow;\
        label += "\\n" + eventLabel(activeEventType);\
\
        if (now < particleUntil)\
        \{\
            // keep particles alive briefly during the active effect\
        \}\
        else\
        \{\
            stopParticles();\
        \}\
    \}\
    else\
    \{\
        stopParticles();\
\
        if (totalWatchers > 0)\
        \{\
            color = <0.90, 0.95, 1.0> * pulse;\
            baseGlow = clampFloat(baseGlow + (0.02 * (float)clampInt(totalWatchers, 0, 5)), 0.02, 0.25);\
        \}\
        else\
        \{\
            color = <0.80, 0.82, 0.88> * pulse;\
        \}\
    \}\
\
    applyVisualState(color, baseGlow, label);\
\}\
